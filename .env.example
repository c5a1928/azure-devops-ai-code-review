# Redis / Celery / App
REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/0
DATABASE_URL=postgresql+psycopg://app:app@localhost:5433/code_review
APP_SECRET_KEY=
ADMIN_PASSWORD=

# Keycloak (default auth provider)
KEYCLOAK_ENABLED=true
KEYCLOAK_INTERNAL_URL=http://localhost:8081
KEYCLOAK_PUBLIC_URL=http://localhost:8081
KEYCLOAK_REALM=plyrev
KEYCLOAK_CLIENT_ID=plyrev-web

# Set KEYCLOAK_ENABLED=false and ADMIN_PASSWORD to use legacy password auth instead.

# Optional bootstrap (imported on first run; then use the web console)
GIT_PLATFORM=azure_devops
GIT_BASE_URL=https://dev.azure.com
GIT_OWNER=your-org
GIT_DEFAULT_PROJECT=your-project
GIT_TOKEN=

# LLM (OpenAI-compatible API for code review)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# gpt-5.5 recommended for thorough reviews; gpt-4o is cheaper but less detailed
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=high
OPENAI_TEMPERATURE=0
# Include headroom for internal reasoning tokens (reasoning + output combined)
OPENAI_MAX_TOKENS=16384

# Gmail notification sender (optional)
GMAIL_USER=
GMAIL_APP_PASSWORD=
