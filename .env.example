# Azure DevOps
AZURE_DEVOPS_BASE_URL=https://dev.azure.com
AZURE_DEVOPS_ORG=your-org
AZURE_DEVOPS_PROJECT=your-project
AZURE_DEVOPS_PAT=your-personal-access-token
# UI label "Acceptance Criteria" maps to Microsoft.VSTS.Common.AcceptanceCriteria

# Redis / Celery
REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/0

# LLM (OpenAI-compatible API for code review)
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
# gpt-5.5 recommended for thorough reviews; gpt-4o is cheaper but less detailed
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=high
OPENAI_TEMPERATURE=0
# Include headroom for internal reasoning tokens (reasoning + output combined)
OPENAI_MAX_TOKENS=16384

# Gmail notification sender (must be a Google App Password, not your login password)
# 1. Enable 2-Step Verification on the Google account
# 2. Create an app password at https://myaccount.google.com/apppasswords
# 3. Paste the 16-character password below (spaces are optional)
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
