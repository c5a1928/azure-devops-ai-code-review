# =============================================================================
# PlyRev environment configuration
# =============================================================================
# Copy to .env and fill in values before deployment:
#   cp .env.example .env
#
# Docker Compose reads this file for api/worker (env_file). Several service
# settings below are also passed into compose via ${VAR} substitution.
#
# Local dev defaults match `docker compose up` on localhost.
# For production: set strong secrets, your public URLs, and real API keys.
# =============================================================================

# -----------------------------------------------------------------------------
# Public URLs (production)
# -----------------------------------------------------------------------------
# Hostname or URL users type in the browser. Used for Keycloak redirects and
# OAuth. Must match Keycloak realm redirect URIs (see keycloak/plyrev-realm.json).
#
# Single-server (compose ports 8090 / 8081):
#   APP_PUBLIC_URL=http://your-server:8090
#   KEYCLOAK_PUBLIC_URL=http://your-server:8081
#
# Behind HTTPS reverse proxy (recommended for production):
#   APP_PUBLIC_URL=https://plyrev.example.com
#   KEYCLOAK_PUBLIC_URL=https://auth.plyrev.example.com
APP_PUBLIC_URL=http://localhost:8090
KEYCLOAK_PUBLIC_URL=http://localhost:8081

# -----------------------------------------------------------------------------
# Application secrets
# -----------------------------------------------------------------------------
# Required in production. Generate with: openssl rand -base64 32
APP_SECRET_KEY=

# Legacy password login (only when KEYCLOAK_ENABLED=false)
ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# PostgreSQL (docker compose `postgres` service)
# -----------------------------------------------------------------------------
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=code_review
# Host port published by compose (local dev only; do not expose in prod firewall)
POSTGRES_PORT=5433

# App/worker connection string — overridden inside Docker to use service name
# `postgres`. For local non-Docker runs, point at localhost:POSTGRES_PORT.
DATABASE_URL=postgresql+psycopg://app:change-me-in-production@localhost:5433/code_review

# -----------------------------------------------------------------------------
# Redis / Celery
# -----------------------------------------------------------------------------
# Overridden inside Docker to redis://redis:6379/0
REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/0

# -----------------------------------------------------------------------------
# Keycloak authentication (default)
# -----------------------------------------------------------------------------
KEYCLOAK_ENABLED=true
# Internal URL — always the Docker service name when using compose
KEYCLOAK_INTERNAL_URL=http://keycloak:8080
KEYCLOAK_REALM=plyrev
KEYCLOAK_CLIENT_ID=plyrev-web
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-in-production

# Set KEYCLOAK_ENABLED=false and ADMIN_PASSWORD to use legacy password auth.

# -----------------------------------------------------------------------------
# Optional bootstrap (imported on first run only; then use the web console)
# -----------------------------------------------------------------------------
# Git platform defaults — configure fully via Integrations → Git platform
GIT_PLATFORM=azure_devops
GIT_BASE_URL=https://dev.azure.com
GIT_OWNER=your-org
GIT_DEFAULT_PROJECT=your-project
GIT_DEFAULT_REPO=your-repo
GIT_TOKEN=

# Azure DevOps legacy aliases (optional)
AZURE_DEVOPS_BASE_URL=https://dev.azure.com
AZURE_DEVOPS_ORG=your-org
AZURE_DEVOPS_PROJECT=your-project
AZURE_DEVOPS_PAT=

# LLM provider (OpenAI-compatible API for code review)
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# gpt-5.5 recommended for thorough reviews; gpt-4o is cheaper but less detailed
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=high
OPENAI_TEMPERATURE=0
# Include headroom for internal reasoning tokens (reasoning + output combined)
OPENAI_MAX_TOKENS=16384

# Gmail notification sender (optional)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# -----------------------------------------------------------------------------
# Production checklist
# -----------------------------------------------------------------------------
# 1. Set APP_SECRET_KEY, POSTGRES_PASSWORD, KEYCLOAK_ADMIN_PASSWORD to unique values
# 2. Set APP_PUBLIC_URL and KEYCLOAK_PUBLIC_URL to your real public URLs
# 3. Update keycloak/plyrev-realm.json redirectUris and webOrigins for your domain
# 4. Set OPENAI_API_KEY (and optional GIT_TOKEN bootstrap) or configure in the UI
# 5. Do not expose POSTGRES_PORT or Redis to the public internet
# 6. Put HTTPS in front of the app and Keycloak (reverse proxy / load balancer)
